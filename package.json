{
  "name": "workspace-dependencies",
  "displayName": "Workspace Dependencies",
  "version": "1.0.0",
  "description": "Track NPM package versions across your workspace and Git branches.",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.80.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "workspaceDeps.openDashboard",
        "title": "Workspace Dependencies: Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Workspace Dependencies Configuration",
      "properties": {
        "workspaceDependencies.watchedDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional directory paths to scan for projects. Can be absolute paths, home relative paths (~), or relative to the workspace root. These folders will be scanned for package.json at their root and one level deep."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "start": "ts-node src/index.ts"
  },
  "dependencies": {
    "glob": "^10.0.0",
    "simple-git": "^3.0.0"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.4"
  }
}